# ============================================
# Privoo - Environment Variables (Example)
# ============================================
# Note: Copy this file to .env and add your real keys
# Never commit .env to version control!

# Firebase Configuration
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_DATABASE_URL=https://your_project-default-rtdb.firebaseio.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# Link Preview API
LINK_PREVIEW_API_KEY=your_link_preview_api_key_here

# Admin Credentials (Change this!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password_immediately